# =============================================================================
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# --- Comments (Giscus - GitHub Discussions)
# Set up at https://giscus.app/ then add the repo and install the app.
# Required for comments to appear on posts.
NEXT_PUBLIC_GISCUS_REPO=SkyeClover/WalkerJacobBlog
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# --- Optional: Analytics
# NEXT_UMAMI_ID=

# --- Optional: Blog audio / video upload (Vercel Blob)
# Public file URLs use your store’s base, e.g.:
#   https://jh7vz8gx5jdayviq.public.blob.vercel-storage.com/<path>
# Store ID (Vercel → Storage): store_Jh7vZ8gX5JDayVIQ
#
# Link the Blob store to the project, then either:
#   - Use BLOB_READ_WRITE_TOKEN (Vercel often sets this when you connect the store), or
#   - Copy the token into BLOB_READ_WRITE_TOKEN from the store’s “.env.local” snippet, or
#   - If Vercel created store_Jh7vZ8gX5JDayVIQ_READ_WRITE_TOKEN (or similar), the upload API
#     also checks that name (see lib/blob-token.ts).
# BLOB_READ_WRITE_TOKEN=
# BLOG_AUDIO_UPLOAD_SECRET=
# BLOG_VIDEO_UPLOAD_SECRET=

# --- Optional: Oura OAuth callback (for Personality Matrix / Oura apps)
# Required if you use the /oura/callback route. In Oura dashboard set Redirect URI to:
#   https://www.walkerjacob.com/oura/callback  (or YOUR_DEPLOYMENT_URL/oura/callback)
# OURA_CLIENT_ID=
# OURA_CLIENT_SECRET=
# OURA_REDIRECT_URI=https://www.walkerjacob.com/oura/callback
# OURA_RETURN_URL=https://www.walkerjacob.com

# --- Newsletter (Buttondown API) – only if you use Pliny <BlogNewsletterForm /> in MDX
# (Homepage uses Buttondown embed; no key needed.) https://buttondown.com/keys
# BUTTONDOWN_API_KEY=

# --- Optional: Static export / base path
# EXPORT=
# BASE_PATH=
# UNOPTIMIZED=
