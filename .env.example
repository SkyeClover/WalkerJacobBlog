# =============================================================================
# Copy to .env.local and fill in values. Never commit .env.local.
# =============================================================================

# --- Comments (Giscus - GitHub Discussions)
# Set up at https://giscus.app/ then add the repo and install the app.
# Required for comments to appear on posts.
NEXT_PUBLIC_GISCUS_REPO=SkyeClover/WalkerJacobBlog
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# --- Optional: Analytics
# NEXT_UMAMI_ID=

# --- Optional: Blog audio upload (Vercel Blob)
# BLOG_AUDIO_UPLOAD_SECRET=
# BLOB_READ_WRITE_TOKEN= or blog_recording_READ_WRITE_TOKEN=

# --- Optional: Static export / base path
# EXPORT=
# BASE_PATH=
# UNOPTIMIZED=
